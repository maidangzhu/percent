{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "percent-tracker",
  "version": "0.1.0",
  "identifier": "com.percent-tracker.app",
  "build": {
    "beforeDevCommand": "pnpm run dev:vite",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "bubble",
        "url": "/bubble",
        "title": "Percent Tracker",
        "width": 640,
        "height": 320,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "transparent": true,
        "acceptFirstMouse": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "shadow": false,
        "center": false,
        "x": 0,
        "y": 0
      },
      {
        "label": "main",
        "url": "/main",
        "title": "Percent Tracker",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 480,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
