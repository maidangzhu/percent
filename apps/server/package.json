{
  "name": "percent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run auth:generate && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "pnpm run auth:generate && tsc",
    "db:push": "mkdir -p ${PERCENT_HOME:-$HOME/.percent-tracker} && prisma db push",
    "db:studio": "mkdir -p ${PERCENT_HOME:-$HOME/.percent-tracker} && prisma studio",
    "auth:generate": "prisma generate --config prisma-auth.config.ts",
    "auth:db:push": "prisma db push --config prisma-auth.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@better-auth/prisma-adapter": "^1.6.11",
    "@hono/node-server": "^2.0.3",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.191",
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
