generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Log {
  id             BigInt     @id @default(autoincrement())
  occurredAt     DateTime   @map("occurred_at") @db.Timestamptz
  appName        String     @map("app_name")
  appBundleId    String     @default("") @map("app_bundle_id")
  isSend         Boolean    @default(false) @map("is_send")
  isWechat       Boolean    @default(false) @map("is_wechat")
  screenshotPath String?    @map("screenshot_path")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  chatTurns      ChatTurn[]

  @@index([occurredAt(sort: Desc)], map: "idx_logs_occurred_at")
  @@index([appBundleId], map: "idx_logs_app_bundle_id")
  @@map("logs")
}

model Person {
  id        BigInt     @id @default(autoincrement())
  name      String
  clientApp String     @default("WeChat") @map("client_app")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  chatTurns ChatTurn[]

  @@unique([name, clientApp])
  @@map("people")
}

model ChatTurn {
  id            BigInt        @id @default(autoincrement())
  logId         BigInt        @map("log_id")
  personId      BigInt        @map("person_id")
  topic         String        @default("")
  capturedAt    DateTime      @map("captured_at") @db.Timestamptz
  rawAiResponse Json?         @map("raw_ai_response")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  log           Log           @relation(fields: [logId], references: [id], onDelete: Cascade)
  person        Person        @relation(fields: [personId], references: [id])
  messages      ChatMessage[]

  @@index([personId], map: "idx_chat_turns_person_id")
  @@index([logId], map: "idx_chat_turns_log_id")
  @@map("chat_turns")
}

model ChatMessage {
  id        BigInt   @id @default(autoincrement())
  turnId    BigInt   @map("turn_id")
  role      String
  content   String
  seq       Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  turn      ChatTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([turnId, seq], map: "idx_chat_messages_turn_id")
  @@map("chat_messages")
}
